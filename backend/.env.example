## Backend Environment Variables (local / Render)
## Copy this file to `.env` and fill values.
## NOTE: Never commit `.env` to git.

# Server port (optional)
PORT=5000

# MongoDB connection string
# Local example:
# MONGO_URI=mongodb://127.0.0.1:27017/emitraDB
# Atlas example:
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/emitraDB?retryWrites=true&w=majority
MONGO_URI=

# JWT settings (required for admin login)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Auto-create superadmin on first run (optional but recommended)
# If set, server will create superadmin user once (if not already exists).
SUPERADMIN_EMAIL=superadmin@emitra.com
SUPERADMIN_PASSWORD=change_me

# CORS allowed origins (comma-separated)
# Local + Vercel examples:
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:5173

# Public API URL (no trailing slash) — used when building file URLs returned to the client
PUBLIC_API_URL=http://localhost:5000

# Default fee when service fee text cannot be parsed (rupees)
DEFAULT_SERVICE_AMOUNT_RUPEES=50

# Razorpay — https://razorpay.com/
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Twilio WhatsApp (optional) — notify admin on new service request
#
# Values must be E.164 WITHOUT the "whatsapp:" prefix (the code adds it).
#
# Sandbox (most common when testing):
# - TWILIO_WHATSAPP_FROM is usually: +14155238886
# - ADMIN_WHATSAPP_TO must be the WhatsApp number you joined the sandbox WITH,
#   e.g. +919876543210 (include country code).
# - You must send "join <code>" from that phone to the Twilio sandbox number first.
#
# Production (Meta-approved WhatsApp sender):
# - TWILIO_WHATSAPP_FROM is your Twilio WhatsApp-enabled sender (E.164).
# - ADMIN_WHATSAPP_TO is the admin’s WhatsApp (E.164).
#
# If any of these are blank, the server skips sending (no crash).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
ADMIN_WHATSAPP_TO=
